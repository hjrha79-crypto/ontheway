<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- ═══ HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OnTheWay"
            android:textSize="18sp"
            android:textColor="#000000"
            android:fontFamily="sans-serif-medium"
            android:paddingEnd="12dp" />

        <TextView
            android:id="@+id/earningText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0원"
            android:textSize="18sp"
            android:textColor="#5B6ABF"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/svcBtn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="접근성"
            android:textSize="11sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/favBtn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="즐겨찾기"
            android:textSize="11sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/settingsBtn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="설정"
            android:textSize="11sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/statsBtn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="통계"
            android:textSize="11sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />
    </LinearLayout>

    <!-- 수익 서브 + 프로그레스 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/earningMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0콜 · 0원/h · 목표 100,000원"
            android:textSize="11sp"
            android:textColor="#999999"
            android:paddingBottom="5dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/progress_track_bg">
            <View
                android:id="@+id/progressFill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/progress_fill_bg" />
        </FrameLayout>
    </LinearLayout>

    <!-- 즐겨찾기 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="10dp">
        <LinearLayout
            android:id="@+id/placesRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- ═══ CHAT ═══ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none"
        android:background="#F5F5F5">
        <LinearLayout
            android:id="@+id/chatLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp" />
    </ScrollView>

    <!-- ═══ CALL CARD ═══ -->
    <LinearLayout
        android:id="@+id/resultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/call_card_bg_v5"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="6dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp"
        android:elevation="4dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/resultRoute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textColor="#666666" />
            <TextView
                android:id="@+id/detailBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="상세"
                android:textSize="11sp"
                android:textColor="#999999"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/detail_btn_bg"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/resultAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="44sp"
            android:textColor="#000000"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.03" />

        <TextView
            android:id="@+id/resultTag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#5B6ABF"
            android:paddingTop="2dp"
            android:paddingBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/acceptBtn"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="3"
                android:layout_marginEnd="8dp"
                android:text="수락하기"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:background="@drawable/accept_btn_bg"
                android:visibility="invisible" />
            <TextView
                android:id="@+id/skipBtn"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="넘기기"
                android:textSize="14sp"
                android:textColor="#666666"
                android:gravity="center"
                android:background="@drawable/skip_btn_bg_new" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ INPUT ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/micBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="🎤"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@drawable/mic_bg" />

        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:hint="메시지 입력..."
            android:textSize="15sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:background="@drawable/input_field_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:imeOptions="actionSend" />

        <TextView
            android:id="@+id/sendBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="↑"
            android:textSize="20sp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:background="@drawable/send_btn_bg_v3" />
    </LinearLayout>

</LinearLayout>
